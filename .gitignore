# Dependencies - CRITICAL TO IGNORE
node_modules/
/.pnp
.pnp.*
.pnp.js

# Next.js
.next/
out/
/.next/
/out/

# Production builds
/build
/dist

# Testing
/coverage
.nyc_output

# Debug logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
lerna-debug.log*

# Yarn
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions
.yarn-integrity

# TypeScript
*.tsbuildinfo
next-env.d.ts

