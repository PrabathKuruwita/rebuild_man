# Root level gitignore

# ─── Environment Variables ──────────────────────────────────────────────────
.env
.env.local
.env.*.local
.env.production

# ─── Python / Django (Backend) ──────────────────────────────────────────────
backend/venv/
backend/env/
backend/.venv/
backend/__pycache__/
backend/**/__pycache__/
backend/**/*.pyc
backend/**/*.pyo
backend/**/*.pyd
backend/db.sqlite3
backend/db.sqlite3-journal
backend/media/
backend/staticfiles/
backend/static/
backend/.pytest_cache/
backend/.coverage
backend/htmlcov/

# ─── Node.js / Next.js (Frontend) ───────────────────────────────────────────
frontend/node_modules/
frontend/.next/
frontend/out/
frontend/build/
frontend/.pnp
frontend/.pnp.*
frontend/coverage/
frontend/npm-debug.log*
frontend/yarn-debug.log*
frontend/yarn-error.log*
frontend/.yarn/

# ─── IDE / Editor ───────────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
*~

# ─── OS ─────────────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Desktop.ini

# ─── Logs ───────────────────────────────────────────────────────────────────
*.log
logs/

# ─── Temporary Files ────────────────────────────────────────────────────────
*.tmp
*.temp
