# ============================================================================

# Python bytecode
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
*.pyc
*.pyo

# Virtual Environments - CRITICAL TO IGNORE
venv/
env/
ENV/
.venv/
.venv
env.bak/
venv.bak/
pip-log.txt
pip-delete-this-directory.txt

# Django
*.log
local_settings.py
db.sqlite3
db.sqlite3-journal
media/
staticfiles/
static/
*.pot

# Distribution / packaging
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
share/python-wheels/
*.egg-info/
.installed.cfg
*.egg
MANIFEST
.Python

