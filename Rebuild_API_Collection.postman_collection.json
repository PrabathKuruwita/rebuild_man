          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Upload returns 201', function () {",
                  "    pm.response.to.have.status(201);",
                  "});",
                  "",
                  "var data = pm.response.json();",
                  "if (data && data.id) {",
                  "    pm.environment.set('document_id', String(data.id));",
